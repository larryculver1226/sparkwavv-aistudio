rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // GLOBAL SAFETY NET
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // PRIMITIVE HELPERS
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider == "google.com" ||
        request.auth.token.email.lower() == "larry.culver1226@gmail.com"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isVerified() && (
        request.auth.token.email.lower() == "larry.culver1226@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isRecent(time) {
      return time is timestamp && time <= request.time && time > request.time - duration.value(5, 'm');
    }

    function isCoachOf(tenantId) {
      return isVerified() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['mentor', 'admin'];
    }

    function isPartnerOf(userId) {
      return isVerified() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             exists(/databases/$(database)/documents/partner_access/$(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId + '_' + userId));
    }

    // ===============================================================
    // VALIDATION BLUEPRINTS
    // ===============================================================

    function isValidUser(data) {
      let required = ['uid', 'email', 'tenantId', 'role'];
      return data.keys().hasAll(required) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() < 256 &&
             data.tenantId is string && data.tenantId.size() < 128 &&
             data.role in ['admin', 'user', 'operator', 'mentor', 'agent', 'super_admin', 'editor', 'viewer'] &&
             (!('sparkwavvId' in data) || data.sparkwavvId is string) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidWavvault(data) {
      return data.keys().hasAll(['userId', 'tenantId']) &&
             data.userId == request.auth.uid &&
             data.tenantId is string &&
             (!('strengths' in data) || (data.strengths is list && data.strengths.size() <= 50)) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidDashboard(data) {
      return data.keys().hasAll(['userId', 'tenantId']) &&
             data.userId == request.auth.uid &&
             data.tenantId is string &&
             (!('careerHappiness' in data) || (data.careerHappiness is int && data.careerHappiness >= 0 && data.careerHappiness <= 100));
    }

    function isValidArtifact(data) {
      let required = ['id', 'userId', 'tenantId', 'filename', 'type', 'storagePath', 'createdAt'];
      return data.keys().hasAll(required) &&
             data.userId == request.auth.uid &&
             data.id is string &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // DOMAIN RULES
    // ===============================================================

    // Connectivity test path
    match /_system_/connectivity_test {
      allow read: if true;
    }

    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin() || isPartnerOf(uid);
      allow list: if isAdmin();
      allow create: if isVerified() && isOwner(uid) && isValidUser(incoming());
      allow update: if isVerified() && isOwner(uid) && 
                      isValidUser(incoming()) &&
                      incoming().uid == existing().uid &&
                      incoming().tenantId == existing().tenantId &&
                      (incoming().role == existing().role || isAdmin());
    }

    match /admins/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isAdmin();
    }

    match /tenants/{tenantId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /dashboards/{userId} {
      allow get: if isOwner(userId) || isAdmin() || isPartnerOf(userId);
      allow list: if isAdmin();
      allow create: if isVerified() && isOwner(userId) && isValidDashboard(incoming());
      allow update: if isVerified() && isOwner(userId) && 
                      isValidDashboard(incoming()) &&
                      incoming().userId == existing().userId &&
                      incoming().tenantId == existing().tenantId;
    }

    match /wavvault/{userId} {
      allow get: if isOwner(userId) || isAdmin() || isPartnerOf(userId);
      allow list: if isAdmin();
      allow create: if isVerified() && isOwner(userId) && isValidWavvault(incoming());
      allow update: if isVerified() && isOwner(userId) && 
                      isValidWavvault(incoming()) &&
                      incoming().userId == existing().userId &&
                      incoming().tenantId == existing().tenantId;
    }

    match /artifacts/{artifactId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isVerified() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isOwner(incoming().userId) && isValidArtifact(incoming());
      allow delete: if isVerified() && isOwner(resource.data.userId);
    }

    match /metadata/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /journey_stages/{stageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /programs/{programId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /cohorts/{cohortId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /journeys/{journeyId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isVerified() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isOwner(incoming().userId);
      allow update: if isVerified() && isOwner(existing().userId) && incoming().userId == existing().userId;
    }

    // Interaction Collections
    match /invitations/{invitationId} {
      allow get: if isSignedIn() && (isOwner(resource.data.senderId) || request.auth.token.email == resource.data.recipientEmail || isAdmin());
      allow list: if isVerified() && (resource.data.senderId == request.auth.uid || resource.data.recipientEmail == request.auth.token.email);
      allow create: if isVerified() && isOwner(incoming().senderId);
      allow update: if isVerified() && (isOwner(existing().senderId) || request.auth.token.email == resource.data.recipientEmail);
    }

    match /user_activities/{activityId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isVerified() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isOwner(incoming().userId);
    }

    // Restricted Systems
    match /security_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    match /system_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }
    
    match /partner_access/{accessId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.userUid) || isCoachOf(resource.data.tenantId) || isAdmin());
      allow create: if isAuthenticated() && (isOwner(request.resource.data.userUid) || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAuthenticated() && (isOwner(resource.data.userUid) || isAdmin());
    }
  }
}
