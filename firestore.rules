rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // 0. GLOBAL SAFETY NET
    // ==========================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // 1. PRIMITIVES & HELPERS
    // ==========================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'larry.culver1226@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ==========================================
    // 2. VALIDATION BLUEPRINTS (Harden with metadata)
    // ==========================================

    function isValidUser(data) {
      return data.uid == request.auth.uid 
          && data.email is string && data.email.size() <= 256
          && (data.tenantId is string || !('tenantId' in data));
    }

    function isValidResource(data) {
      return data.userId == request.auth.uid
          && (data.tenantId is string || !('tenantId' in data));
    }

    function isValidInvitation(data) {
      return data.senderId == request.auth.uid
          && data.senderEmail is string && data.senderEmail.size() <= 256
          && data.recipientEmail is string && data.recipientEmail.size() <= 256
          && data.status in ['pending', 'accepted', 'declined'];
    }

    function isValidPartnerAccess(data) {
      return data.ownerId is string && data.ownerId.size() <= 128
          && data.partnerId is string && data.partnerId.size() <= 128
          && data.status in ['active', 'revoked'];
    }

    // ==========================================
    // 3. COLLECTION RULES
    // ==========================================

    // --- Users (PII Protected) ---
    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin() || (isOwner(uid) && resource.data.uid == request.auth.uid);
      
      allow create: if isOwner(uid) && isValidUser(incoming()) && incoming().role == 'user';
      allow update: if (isOwner(uid) && isValidUser(incoming()) && incoming().role == existing().role)
                    || isAdmin();
    }

    // --- Core Personal Data (Query Enforced) ---
    match /dashboards/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isOwner(userId) && isValidResource(incoming());
      allow update: if (isOwner(userId) && incoming().userId == existing().userId && isValidResource(incoming())) || isAdmin();
    }

    match /wavvault/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isOwner(userId) && isValidResource(incoming());
      allow update: if (isOwner(userId) && incoming().userId == existing().userId && isValidResource(incoming())) || isAdmin();
    }

    // --- Assets & Artifacts ---
    match /user_assets/{assetId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /artifacts/{artifactId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // --- Multi-User: Invitations ---
    match /invitations/{invitationId} {
      allow get: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientEmail == request.auth.token.email || isAdmin());
      allow list: if isAdmin() || (isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientEmail == request.auth.token.email));
      
      allow create: if isSignedIn() && isValidInvitation(incoming()) && incoming().status == 'pending';
      allow update: if isSignedIn() && (
        (resource.data.recipientEmail == request.auth.token.email && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        (resource.data.senderId == request.auth.uid && resource.data.status == 'pending' && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        isAdmin()
      );
    }

    // --- Multi-User: Partner Access ---
    match /partner_access/{accessId} {
      allow read: if isSignedIn() && (resource.data.ownerId == request.auth.uid || resource.data.partnerId == request.auth.uid || isAdmin());
      allow list: if isAdmin() || (isSignedIn() && (resource.data.ownerId == request.auth.uid || resource.data.partnerId == request.auth.uid));
      
      allow create: if isSignedIn() && resource.data.ownerId == request.auth.uid && isValidPartnerAccess(incoming());
      allow update: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid && incoming().ownerId == existing().ownerId);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // --- Public Metadata & Config ---
    match /metadata/{documentId} { allow read: if true; allow write: if isAdmin(); }
    match /tenants/{tenantId} { allow read: if true; allow write: if isAdmin(); }
    match /programs/{programId} { allow read: if true; allow write: if isAdmin(); }
    match /journey_stages/{stageId} { allow read: if true; allow write: if isAdmin(); }
    match /journeyPhaseConfigs/{configId} { allow read: if true; allow write: if isAdmin(); }

    // --- Journeys & Active States ---
    match /journeys/{journeyId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // --- Agent Sync & Proactive Nudges ---
    match /agent_sync/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isOwner(userId) && isValidResource(incoming());
      allow update: if (isOwner(userId) && incoming().userId == existing().userId && isValidResource(incoming())) || isAdmin();
    }

    match /agent_logs/{logId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /nudges/{nudgeId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin(); 
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read'])) || isAdmin();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // --- Feedback & Logs ---
    match /feedback_issues/{issueId} { allow create: if isSignedIn(); allow read, update: if isAdmin(); }
    match /security_logs/{logId} { allow create: if true; allow read: if isAdmin(); }
    match /system_logs/{logId} { allow create: if true; allow read: if isAdmin(); }

    // --- Admins collection ---
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
