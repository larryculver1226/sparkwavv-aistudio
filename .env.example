# --- FIREBASE CONFIGURATION (Vite Client-side) ---
# Required for browser to connect to Firebase. 
# In AI Studio: Set in Secrets Vault.
# In Production: Set in CI/CD (Cloud Build) environment.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_DATABASE_ID=(default)

# --- APP CONFIGURATION ---
SESSION_SECRET=
APP_URL=
ADMIN_PASSWORD=

# --- GOOGLE CLOUD & FIREBASE ADMIN (Server-side) ---
# Full JSON string of the Service Account Key
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- AI & EXTERNAL SERVICES ---
GEMINI_API_KEY=
GOOGLE_MAPS_API_KEY=

# --- VERTEX AI (Enterprise) ---
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_SEARCH_ENGINE_ID=
VERTEX_AI_SEARCH_DATA_STORE_ID=
