{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:setup": "mkdir -p dist/public && cp index.html dist/public/ && cp -r public/* dist/public/ 2>/dev/null || true",
    "dev:css": "tailwindcss -i ./src/index.css -o ./dist/public/style.css --watch",
    "dev:js": "node scripts/watch-client.mjs",
    "dev:server": "tsx watch server.ts",
    "dev": "npm run dev:setup && concurrently \"npm run dev:css\" \"npm run dev:js\" \"npm run dev:server\"",
    "start": "node dist/server.js",
    "build:css": "tailwindcss -i ./src/index.css -o ./dist/public/style.css --minify",
    "build:js": "node scripts/build-client.mjs",
    "build:server": "esbuild server.ts --bundle --platform=node --target=node20 --outfile=dist/server.js --format=esm --packages=external --minify",
    "build": "mkdir -p dist/public && npm run build:css && npm run build:js && npm run build:server && cp index.html dist/public/ && cp -r public/* dist/public/ 2>/dev/null || true && cp firebase-applet-config.json dist/",
    "preview": "node dist/server.js",
    "update-skills": "node scripts/update-skills.js",
    "clean": "rm -rf dist",
    "lint": "NODE_OPTIONS='--max-old-space-size=4096' tsc --noEmit",
    "qa": "eslint src/ && prettier --check src/",
    "format": "prettier --write src/",
    "generate": "gemini --prompt",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright install chromium && playwright test",
    "test:e2e:smoke": "playwright install chromium && playwright test --grep @smoke",
    "check-env": "tsx -e 'import(\"./src/config.ts\").then(m => m.validateConfig()).catch(e => { console.error(e.message); process.exit(1); })'"
  },
  "dependencies": {
    "@genkit-ai/core": "^1.32.0",
    "@genkit-ai/dotprompt": "^0.9.12",
    "@genkit-ai/googleai": "^1.28.0",
    "@genkit-ai/vertexai": "^1.32.0",
    "@google-cloud/aiplatform": "^6.5.0",
    "@google-cloud/discoveryengine": "^2.6.0",
    "@google-cloud/storage": "^7.19.0",
    "@google-cloud/vertexai": "^1.10.0",
    "@google/genai": "^1.29.0",
    "@langchain/core": "^1.1.39",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/google-vertexai": "^2.1.26",
    "@langchain/langgraph": "^1.2.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sendgrid/mail": "^8.1.6",
    "@types/d3": "^7.4.3",
    "@types/express-session": "^1.18.2",
    "axios": "^1.14.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "d3": "^7.9.0",
    "docx": "^9.6.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "fast-xml-parser": "^5.5.8",
    "file-saver": "^2.0.5",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.8.0",
    "formidable": "^3.5.4",
    "helmet": "^8.1.0",
    "json-schema-to-zod": "^2.8.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.23.24",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-easy-crop": "^5.5.6",
    "react-helmet-async": "^3.0.0",
    "react-is": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@google/gemini-cli": "^0.36.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/cli": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/formidable": "^3.5.1",
    "@types/next": "^8.0.7",
    "@types/node": "^22.14.0",
    "@types/uuid": "^10.0.0",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.0"
  }
}
