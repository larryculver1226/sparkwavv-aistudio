{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node dist/server.js",
    "build": "vite build && npx esbuild server.ts --bundle --platform=node --target=node20 --outfile=dist/server.js --format=esm --packages=external --minify && cp firebase-applet-config.json dist/",
    "preview": "vite preview",
    "update-skills": "node scripts/update-skills.js",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "qa": "eslint src/ && prettier --check src/",
    "format": "prettier --write src/",
    "generate": "gemini --prompt",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright install chromium && playwright test",
    "test:e2e:smoke": "playwright install chromium && playwright test --grep @smoke"
  },
  "dependencies": {
    "@google-cloud/discoveryengine": "^2.6.0",
    "@google-cloud/storage": "^7.19.0",
    "@google-cloud/vertexai": "^1.10.0",
    "@google/genai": "^1.29.0",
    "@langchain/core": "^1.1.39",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/google-vertexai": "^2.1.26",
    "@langchain/langgraph": "^1.2.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sendgrid/mail": "^8.1.6",
    "@tailwindcss/vite": "^4.1.14",
    "@types/d3": "^7.4.3",
    "@types/express-session": "^1.18.2",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.14.0",
    "better-sqlite3": "^12.4.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "docx": "^9.6.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "fast-xml-parser": "^5.5.8",
    "file-saver": "^2.0.5",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.7.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.23.24",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-easy-crop": "^5.5.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@google/gemini-cli": "^0.36.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/next": "^8.0.7",
    "@types/node": "^22.14.0",
    "@types/uuid": "^10.0.0",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.2.0",
    "vitest": "^4.1.0"
  }
}
